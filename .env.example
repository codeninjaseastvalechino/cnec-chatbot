# ============================================================
# CNEC Chatbot — Environment Variable Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to git — it contains real credentials.
# ============================================================

# --- Site 2: LineLeader ---
LINELEADER_USERNAME=
LINELEADER_PASSWORD=

# --- Site 1: MyStudio (added in Milestone 2) ---
MYSTUDIO_USERNAME=
MYSTUDIO_PASSWORD=
# Center-specific IDs — REQUIRED (app refuses to start without them).
# Eastvale Chino: MYSTUDIO_COMPANY_ID=578, MYSTUDIO_USER_ID=9901
MYSTUDIO_COMPANY_ID=
MYSTUDIO_USER_ID=

# --- Site 3: Homebase ---
# NOTE: Homebase credentials are NEVER stored here.
# They are entered by the owner at runtime and held in memory only.

# --- Milestone 5: Claude API (Chatbot) ---
ANTHROPIC_API_KEY=
CLAUDE_MODEL=

# -- Google App Password for MyStudio 2FA Code Extraction (added in Milestone 2) ---
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=

# --- Web session / multi-user isolation ---
# SECRET_KEY signs the Flask session cookie so each browser gets its own isolated
# conversation. REQUIRED in production. If empty, the app uses a throwaway key and
# every browser's chat resets on each server restart.
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
# Minutes of inactivity before a browser's conversation context is dropped (default 30).
SESSION_IDLE_MINUTES=30

# --- Timezone (required for correct date/time filtering) ---
# CENTER_TIMEZONE anchors the assistant's sense of "today"/"now" — pinned in the app,
# so the date is correct regardless of where it's hosted (set per center).
CENTER_TIMEZONE=America/Los_Angeles
# TZ sets the host process timezone (belt-and-suspenders for log timestamps on cloud).
TZ=America/Los_Angeles
