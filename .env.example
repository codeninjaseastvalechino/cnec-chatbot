# ============================================================
# CNEC Chatbot — Environment Variable Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to git — it contains real credentials.
# ============================================================

# --- Site 2: LineLeader / ChildCareCRM ---
LINELEADER_USERNAME=your_lineleader_email@codeninjas.com
LINELEADER_PASSWORD=your_lineleader_password

# --- Site 1: MyStudio (added in Milestone 2) ---
# MYSTUDIO_USERNAME=your_mystudio_username
# MYSTUDIO_PASSWORD=your_mystudio_password

# --- Microsoft Graph API for MyStudio 2FA (added in Milestone 2) ---
# GRAPH_CLIENT_ID=your_azure_app_client_id
# GRAPH_CLIENT_SECRET=your_azure_app_client_secret
# GRAPH_TENANT_ID=your_azure_tenant_id
# GRAPH_MAILBOX=shared_inbox@yourdomain.com

# --- Site 3: Homebase ---
# NOTE: Homebase credentials are NEVER stored here.
# They are entered by the owner at runtime and held in memory only.
