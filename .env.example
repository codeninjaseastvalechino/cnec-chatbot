# ============================================================
# CNEC Chatbot — Environment Variable Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to git — it contains real credentials.
# ============================================================

# --- Site 2: LineLeader / ChildCareCRM ---
LINELEADER_USERNAME=your_lineleader_email@codeninjas.com
LINELEADER_PASSWORD=your_lineleader_password

# --- Site 1: MyStudio (added in Milestone 2) ---
MYSTUDIO_USERNAME=your_mystudio_username
MYSTUDIO_PASSWORD=your_mystudio_password
MYSTUDIO_ORG_ID=your_center_id        # e.g., 12345
MYSTUDIO_CENTER_ID=your_location_id   # if different from org_id

# --- Gmail IMAP for MyStudio 2FA Code Extraction ---
# Setup: Enable 2FA on the Gmail account receiving MyStudio 2FA codes
#   1. https://myaccount.google.com/security → enable 2-step verification
#   2. https://myaccount.google.com/apppasswords → generate app password
#   3. Select "Mail" and "Custom (type: MyStudio 2FA)"
#   4. Copy the 16-character password below (spaces optional)
GMAIL_ADDRESS=shared_inbox@gmail.com       # Gmail account receiving 2FA codes
GMAIL_APP_PASSWORD=abcd efgh ijkl mnop    # Gmail app password (16 chars)
GMAIL_2FA_TIMEOUT_SECONDS=120               # Max wait for code (default 120)

# --- Site 3: Homebase ---
# NOTE: Homebase credentials are NEVER stored here.
# They are entered by the owner at runtime and held in memory only.

# --- LLM Provider (Milestone 5 Web UI) ---
# Choose which LLM backend to use: "claude" or "ollama"
# Defaults to "claude" if not specified
LLM_PROVIDER=claude

# Claude API (if LLM_PROVIDER=claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-haiku-4-5

# Ollama (if LLM_PROVIDER=ollama)
# NOTE: Requires Ollama running locally (ollama serve)
# Download Ollama from https://ollama.ai
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=mistral
